# NestJS
NODE_ENV=development
PORT=3000

# Совпадает с docker-compose (сервис db)
POSTGRES_USER=mvp
POSTGRES_PASSWORD=mvp
POSTGRES_DB=mvp
POSTGRES_PORT=5432

# Подключение с хоста к опубликованному порту контейнера
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=mvp
DB_PASSWORD=mvp
DB_NAME=mvp

# Опционально: полный URL вместо полей выше (если задан — имеет приоритет при сборке URL в конфиге)
# DATABASE_URL=postgresql://mvp:mvp@127.0.0.1:5432/mvp
